{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c \"chmod -R a+rwX /data; exec hermes gateway run\"",
    "healthcheckPath": null,
    "restartPolicyType": "ON_FAILURE"
  }
}
